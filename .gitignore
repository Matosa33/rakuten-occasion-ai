# === HuggingFace cache (téléchargements lourds, hors data/raw/cache) ===
~/.cache/huggingface/

# === Audit reports — on garde le markdown commit (synthèse humaine), mais pas
# les artefacts lourds régénérables. dataset_meta_inventory.json reste commité
# pour figer la trace de la décision méta-first (ADR D-008).
reports/figures/*.png
reports/figures/*.svg
!reports/figures/.gitkeep
reports/audit_*_metrics.json

# === MLflow / DVC ===
mlruns/
mlartifacts/
mlruns.db
.dvc/cache
.dvc/tmp
dvc_storage/

# === Autres ===
*.tmp
*.bak
catboost_info/

# === Exceptions : on garde les .dvc metadata files en Git ===
!data/raw/*.dvc
!data/processed/*.dvc
!data/embeddings/*.dvc
!models/**/*.dvc
