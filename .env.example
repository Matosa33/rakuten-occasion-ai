# Copie ce fichier en `.env` (gitignoré) et renseigne tes valeurs.
# JAMAIS commiter `.env` avec des vraies clés.

# OpenRouter - requis pour la lecture des photos (VLM), la validation visuelle
# et la rédaction de fiche (LLM). Sans clé : mode dégradé (retrieval + prix seuls).
# Obtenir une clé : https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Modèles VLM/LLM (optionnels - défauts sains dans le code).
# PHOTO_VLM_IDENTIFY_MODEL = modèle de la passe d'identification raisonnée
# (juge le top-15) ; fallback sur PHOTO_VLM_MODEL.
# PHOTO_VLM_MODEL=qwen/qwen3.5-flash-02-23
# PHOTO_VLM_IDENTIFY_MODEL=qwen/qwen3.5-flash-02-23
# PHOTO_VLM_IDENTIFY_MAX_TOKENS=700
# PHOTO_VLM_PROVIDER=            # épingle un provider OpenRouter précis (reproductibilité)
# PHOTO_VLM_TEMPERATURE=0        # déterminisme de l'extraction photo
# PHOTO_VLM_SEED=42

# Pricing : taux de change appliqué aux prix catalogue (modifiable sans redéploiement).
# PRICE_USD_EUR_RATE=0.92

# Observabilité (optionnel).
# LOG_LEVEL=INFO
# PUSHGATEWAY_URL=http://pushgateway:9091   # http://localhost:9091 hors Docker

# Persistence SQLAlchemy. Défaut SQLite local si non défini.
DATABASE_URL=sqlite:///./rakuten.db

# === Ports Compose ===
# Customise si les ports par défaut sont déjà pris sur ton poste (XAMPP, autres
# uvicorn, Grafana...). Repasser à blanc = défauts ci-dessous.
API_PORT=8010
FRONTEND_PORT=8082
AIRFLOW_PORT=8088
TRAEFIK_PORT=8090            # entrée HTTP unifiée - http://*.localhost:8090
TRAEFIK_DASHBOARD_PORT=8091  # dashboard Traefik (dev only, à fermer en prod)
MLFLOW_PORT=5000             # MLflow tracking server
MINIO_API_PORT=9010          # MinIO S3 endpoint hôte (interne reste 9000)
MINIO_CONSOLE_PORT=9011      # MinIO web console (login minioadmin)
PROMETHEUS_PORT=9090         # Prometheus UI - http://localhost:9090
GRAFANA_PORT=3000            # Grafana UI - login admin/admin par défaut
PUSHGATEWAY_PORT=9091        # Pushgateway métriques batch

# === Identifiants Grafana ===
# Défauts dev OK. En prod : générer un mot de passe fort, ne PAS commiter.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# === Identifiants MinIO ===
# Défauts dev OK. En prod : générer aléatoirement, ne PAS commiter.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Clé Fernet Airflow (chiffrement secrets internes). Par défaut vide = ephemeral,
# OK pour dev. En prod, générer une vraie clé : `openssl rand -base64 32`.
AIRFLOW_FERNET_KEY=

# === JWT auth ===
# Secret HS256 pour signer les Bearer tokens. EN PROD : générer aléatoire fort :
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Le défaut dev `dev-secret-change-me-in-prod` est volontairement bidon.
JWT_SECRET=dev-secret-change-me-in-prod
JWT_EXPIRE_MINUTES=60
