# Copie ce fichier en `.env` (gitignoré) et renseigne tes valeurs.
# JAMAIS commiter `.env` avec des vraies clés (R2 zéro-secret-dans-code).

# OpenRouter — requis pour /describe (LLM rédacteur E4) et VLM validateur E3 (post-MVP).
# Obtenir une clé : https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Persistence SQLAlchemy (Cycle 9.5). Défaut SQLite local si non défini.
DATABASE_URL=sqlite:///./rakuten.db

# === Ports Compose (Cycle 13.2, D-025) ===
# Customise si les ports par défaut sont déjà pris sur ton poste (XAMPP, autres
# uvicorn, Grafana...). Repasser à blanc = défauts ci-dessous.
API_PORT=8010
FRONTEND_PORT=8082
AIRFLOW_PORT=8088
TRAEFIK_PORT=8090            # entrée HTTP unifiée (C13.3) — http://*.localhost:8090
TRAEFIK_DASHBOARD_PORT=8091  # dashboard Traefik (dev only, à fermer en prod)
MLFLOW_PORT=5000             # MLflow tracking server (C13.4 D-027)
MINIO_API_PORT=9010          # MinIO S3 endpoint hôte (interne reste 9000)
MINIO_CONSOLE_PORT=9011      # MinIO web console (login minioadmin)

# === Identifiants MinIO (C13.4) ===
# Défauts dev OK. En prod : générer aléatoirement, ne PAS commiter (R2).
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Clé Fernet Airflow (chiffrement secrets internes). Par défaut vide = ephemeral,
# OK pour dev. En prod, générer une vraie clé : `openssl rand -base64 32`.
AIRFLOW_FERNET_KEY=
